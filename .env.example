# ── Azure Resource Endpoint (traditional) ────────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-api-key
# AZURE_OPENAI_API_VERSION=2025-04-14

# ── Global Endpoint (models.inference.azure.com) ─────────────────────────────
# OPENAI_API_KEY=your-multi-service-key
# OPENAI_ENDPOINT=https://models.inference.azure.com

# Set USE_GLOBAL_OPENAI=1 to force global endpoint when both are present
# USE_GLOBAL_OPENAI=1

# ── Model / Deployment Names ─────────────────────────────────────────────────
# For Azure resource mode: these are your deployment names
# For global endpoint mode: these are the model names (e.g. gpt-4o, gpt-4o-mini)
AZURE_OPENAI_DEPLOYMENT_4O=gpt-4.1
AZURE_OPENAI_DEPLOYMENT_4O_MINI=gpt-4.1-mini
