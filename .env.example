# ── Azure AI Foundry / OpenAI SDK ────────────────────────────────────────────
# Endpoint must include /openai/v1/ (use the "OpenAI" SDK path from Azure Foundry)
AZURE_OPENAI_ENDPOINT=https://<resource>.cognitiveservices.azure.com/openai/v1/
AZURE_OPENAI_KEY=your-api-key

# ── Deployment names (set to your actual deployed model names) ───────────────
AZURE_OPENAI_DEPLOYMENT_4O=gpt-4.1
AZURE_OPENAI_DEPLOYMENT_4O_MINI=gpt-4.1-mini
